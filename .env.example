# ServiceFlow Pro - Environment Configuration Template
# Copy this file to .env and update the values
# ===========================================

# ===========================================
# ENVIRONMENT CONFIGURATION
# ===========================================
ENVIRONMENT=development
DEBUG=True

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
POSTGRES_USER=serviceflow_admin
POSTGRES_PASSWORD=TuPasswordSeguro123!
POSTGRES_DB=serviceflow_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Database URL (constructed from above variables)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ===========================================
# SECURITY & AUTHENTICATION
# ===========================================
# Generate a secure key with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=tu_clave_secreta_muy_larga_y_segura_cambiala_en_produccion
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===========================================
# CORS CONFIGURATION
# ===========================================
# For development: allow localhost and common dev ports
# For production: replace with your actual domain(s)
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:3000","http://127.0.0.1:5173"]

# ===========================================
# REDIS CONFIGURATION (OPTIONAL)
# ===========================================
REDIS_URL=redis://redis:6379/0

# ===========================================
# EXTERNAL SERVICES
# ===========================================
# BCV API for exchange rate updates (replace with actual service)
BCV_API_URL=https://example-bcv-api.com/rate

# ===========================================
# PROJECT INFO
# ===========================================
PROJECT_NAME=ServiceFlow Pro ERP
API_V1_STR=/api/v1

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=INFO

# ===========================================
# PRODUCTION SETTINGS (Uncomment for production)
# ===========================================
# ENVIRONMENT=production
# DEBUG=false
# SECRET_KEY=<generate-unique-key-for-production>
# BACKEND_CORS_ORIGINS=["https://tudominio.com"]
# LOG_LEVEL=WARNING
